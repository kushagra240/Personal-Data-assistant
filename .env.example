# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# LLM Configuration
# Options: 'huggingface', 'gemini', or 'watsonx'
LLM_PROVIDER=huggingface

# Hugging Face Configuration
HUGGINGFACEHUB_API_TOKEN=your_huggingface_api_token_here
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_ID=gemini-3.5-flash

# IBM Watsonx Configuration
WATSONX_APIKEY=your_watsonx_apikey_here
WATSONX_PROJECT_ID=skills-network
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=meta-llama/llama-4-maverick-17b-128e-instruct-fp8
WATSONX_MAX_NEW_TOKENS=256
WATSONX_TEMPERATURE=0.1

# Vector DB & Embeddings Configuration
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DB_DIR=./data/chroma_db
UPLOAD_DIR=./data/uploads

# Retriever Settings
# Options for RETRIEVER_SEARCH_TYPE: 'similarity', 'mmr'
RETRIEVER_SEARCH_TYPE=similarity
RETRIEVER_K=3
RETRIEVER_LAMBDA_MULT=0.25
